# =============================================
# Variables de Entorno — Intranet BI
# Copia este archivo como .env.local y completa los valores
# =============================================

# ─── Base de Datos (Railway PostgreSQL) ───────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── NextAuth ─────────────────────────────────
NEXTAUTH_SECRET="cambia-esto-por-un-string-aleatorio-de-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (SMTP para recuperación de contraseña) ──
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="correo@empresa.com"
SMTP_PASS="app-password-de-gmail"
SMTP_FROM="Intranet Empresa <correo@empresa.com>"

# ─── Power BI (configurar después) ────────────
POWERBI_TENANT_ID=""
POWERBI_CLIENT_ID=""
POWERBI_CLIENT_SECRET=""
